<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/nextcloud/server/master/apps/firstrunwizard/templates/services.xsd">
    <service id="talk_bot">
        <!-- Controllers -->
        <service id="OCA\TalkBot\Controller\WebhookController">
            <argument key="$appName">talk_bot</argument>
        </service>
        
        <service id="OCA\TalkBot\Controller\SettingsController">
            <argument key="$appName">talk_bot</argument>
        </service>
        
        <!-- Services -->
        <service id="OCA\TalkBot\Service\MessageService">
            <argument key="$appName">talk_bot</argument>
        </service>
        
        <service id="OCA\TalkBot\Service\SettingsService" />
        
        <!-- Event Listeners -->
        <service id="OCA\TalkBot\Listener\ChatMessageListener">
            <argument key="$logger"></argument>
        </service>
    </service>
</services>
