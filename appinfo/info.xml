<?xml version="1.0"?>
<info xmlns:xsi= "http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
    <id>nextcloudtalkbot</id>
    <name>Nextcloud Talk Bot</name>
    <summary>Bot integration for Nextcloud Talk with webhook support</summary>
    <description><![CDATA[
        A Nextcloud Talk Bot that handles webhooks from external services and posts messages to Talk rooms.
        Features secure signature verification, configurable endpoints, and extensible message formatting.
    ]]></description>
    <version>1.0.0</version>
    <licence>agpl</licence>
    <author mail="openclaw@philipp-hoch.de" >OpenClaw Team</author>
    <namespace>NextcloudTalkBot</namespace>
    
    <category>integration</category>
    <category>tools</category>
    
    <bugs>https://github.com/phillihochopenclaw/nextcloud-talk-bot/issues</bugs>
    <repository type="git">https://github.com/phillihochopenclaw/nextcloud-talk-bot.git</repository>
    
    <screenshot small-thumbnail="https://raw.githubusercontent.com/phillihochopenclaw/nextcloud-talk-bot/main/docs/screenshot-small.png">
        https://raw.githubusercontent.com/phillihochopenclaw/nextcloud-talk-bot/main/docs/screenshot.png
    </screenshot>
    
    <dependencies>
        <nextcloud min-version="27" max-version="29"/>
        <php min-version="8.1" max-version="8.3"/>
    </dependencies>
    
    <background-jobs>
        <job>OCA\NextcloudTalkBot\Cron\CleanupJob</job>
    </background-jobs>
    
    <settings>
        <admin>OCA\NextcloudTalkBot\Settings\AdminSettings</admin>
        <admin-section>OCA\NextcloudTalkBot\Settings\AdminSection</admin-section>
    </settings>
    
    <commands>
        <command>OCA\NextcloudTalkBot\Command\ConfigureBot</command>
    </commands>
</info>